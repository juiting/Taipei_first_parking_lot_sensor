# Carin 地端 IoT 服務
CARIN_BASE_URL=http://<CARIN_HOST>:<CARIN_PORT>
CARIN_USERNAME=
CARIN_PASSWORD=

# 輪詢間隔（秒）
POLL_INTERVAL=8

# 感測器離線判斷門檻（小時，最新回報超過此時數視為離線）
OFFLINE_THRESHOLD_HOURS=2

# SQLite 路徑
DB_PATH=data/geomag.sqlite

# API 服務（8600 保留給戰情室 Kiosk，本專案用 8610 避免衝突）
API_HOST=0.0.0.0
API_PORT=8610

# Brickcom 感測器管理平台（電量/RSSI，選填；留空則此功能停用）
# 狀態頁完整網址（含 customer/location 查詢參數）與 debug 服務位址，向廠商索取
BRICKCOM_STATUS_URL=
BRICKCOM_DEBUG_BASE=
BRICKCOM_BATTERY_INTERVAL=300
BRICKCOM_RSSI_INTERVAL=1800
